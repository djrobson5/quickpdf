{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickPDF",
  "version": "0.1.1",
  "identifier": "com.quickpdf.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "QuickPDF",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480,
        "dragDropEnabled": false,
        "additionalBrowserArgs": "--disable-features=msWebView2BrowserHitTransparent,WebContentsForceDark --blink-settings=forceDarkModeEnabled=false"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/djrobson5/quickpdf/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU3MzM3MDg4OUNFQjA3NUEKUldSYUIrdWNpSEF6NTlVdEtNZVhKUlk1QTd2ODU4L2J3UCs4Rjd2TENwa2IvQVlLZVdhQjlCNVAK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "name": "PDF Document",
        "description": "Open with QuickPDF",
        "role": "Editor"
      }
    ]
  }
}
